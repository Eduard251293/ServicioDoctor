# =====================================================
# .env — Variables de entorno del ServicioDoctor
# IMPORTANTE: Este archivo NO debe subirse a GitHub
# Agrega .env a tu .gitignore
# =====================================================

# Clave secreta para firmar los tokens JWT
# Cámbiala por una cadena larga y aleatoria en producción
# Puedes generar una con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=ecosalud_clave_super_secreta_cambiame_en_produccion_2026

# Algoritmo de firma del JWT (HS256 es el estándar para este caso)
JWT_ALGORITHM=HS256

# Tiempo de expiración del token en minutos (60 = 1 hora)
JWT_EXPIRE_MINUTES=60